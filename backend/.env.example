# ===== DeepSeek LLM =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== Supabase PostgreSQL + pgvector =====
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-ID].supabase.co:6543/postgres

# ===== Embedding API（兼容 OpenAI 接口格式）=====
# 可选服务商：阿里云 DashScope / 硅基流动 SiliconFlow / 智谱 AI / OpenAI
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ===== RAG =====
RAG_TOP_K=5

# ===== Server =====
PORT=8000
